<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Hi, I'm Your Name</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    :root {
      --bg: #ffffff;
      --text: #111111;
      --muted: #444444;
      --link: #111111;
      --font-main: "Times New Roman", Georgia, serif;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      padding: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background-color: var(--bg);
      color: var(--text);
      font-family: var(--font-main);
    }

    .page {
      text-align: left;
      max-width: 640px;
      padding: 40px 24px;
    }

    h1 {
      font-size: clamp(2.2rem, 4vw, 2.8rem);
      font-weight: 600;
      margin: 0 0 24px;
      text-align: center;
    }

    .intro {
      font-size: 1rem;
      line-height: 1.7;
      color: var(--muted);
      margin: 0 0 36px;
      text-align: center;
    }

    .links-primary {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-bottom: 40px;
    }

    a {
      color: var(--link);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    a:hover {
      text-decoration-thickness: 2px;
    }

    .icons {
      display: flex;
      justify-content: center;
      gap: 24px;
      margin-bottom: 24px;
      font-size: 1.4rem;
    }

    .icons a {
      text-decoration: none;
    }

    .email {
      text-align: center;
      font-size: 0.95rem;
      margin-top: 8px;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #050507;
        --text: #f5f5f5;
        --muted: #c0c0c0;
        --link: #f5f5f5;
      }
    }
  </style>
</head>
<body>
  <main class="page">
    <h1>Hi, I'm Your Name</h1>

    <p class="intro">
      One or two short sentences about what you're building or working on.
      A second sentence about your current path or what you're trying to learn.
    </p>

    <div class="links-primary">
      <a href="#writing">View my writing</a>
      <a href="#project">Main project or tracker</a>
    </div>

    <div class="icons">
      <!-- Replace href values with your real profiles -->
      <a href="https://github.com/your-handle" aria-label="GitHub" target="_blank" rel="noopener noreferrer">🐙</a>
      <a href="https://www.linkedin.com/in/your-handle" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">in</a>
    </div>

    <div class="email">
      <!-- You can obfuscate your email here if you want -->
      yourname [at] example [dot] com
    </div>
  </main>
</body>
</html>
